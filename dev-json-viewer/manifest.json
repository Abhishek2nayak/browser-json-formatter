{
  "manifest_version": 3,
  "name": "JSON Forge",
  "version": "1.1.0",
  "description": "Automatically detects JSON responses and renders them in a rich collapsible tree with syntax highlighting, search, raw view, and developer tools.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.css", "viewer.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"]
}
